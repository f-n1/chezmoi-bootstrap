# Copy this file to .env and fill in the values.
# .env is gitignored and will not be committed.

# SSH private key used to bootstrap chezmoi, base64 encoded.
# When set, install.sh will use this key instead of prompting for input.
# Paste the entire key content (including BEGIN/END lines) as a single value.
# SSH_BOOTSTRAP_KEY=LS0tLS1CRUdJTiBPUEVOU1NIIFBSSVZBVE...
SSH_BOOTSTRAP_KEY=
