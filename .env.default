# Required — GitHub username for chezmoi init and one-liner URL
GITHUB_USER=<GITHUB_USER>

# Required — age passphrase for encrypting/decrypting key bundles
AGE_PASSPHRASE=<AGE_PASSPHRASE>

# Optional — full chezmoi repo (overrides GITHUB_USER for chezmoi init)
# Examples: gitea.example.com/user/dotfiles, https://git.example.com/user/dotfiles.git
#CHEZMOI_REPO=

# Optional — where to install the chezmoi binary (default: ~/.local/bin)
CHEZMOI_BIN_DIR=$HOME/.local/bin
